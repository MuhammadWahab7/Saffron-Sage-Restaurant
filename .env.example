# Public Supabase values used by the React website.
# Add the same keys to Netlify Environment Variables with Builds access.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY

# Private key used only by the Netlify chatbot Function.
# Add it to Netlify Environment Variables. Do NOT add a VITE_ prefix.
GEMINI_API_KEY=YOUR_PRIVATE_GEMINI_API_KEY

# Optional. The code already uses this model by default.
GEMINI_MODEL=gemini-3.1-flash-lite
